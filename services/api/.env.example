# Copy this to .env and fill in your values
NODE_ENV=development
PORT=3001

# Local Postgres (after: brew install postgresql && brew services start postgresql)
DATABASE_URL=postgresql://postgres:password@localhost:5432/poker_platform

# Local Redis (after: brew install redis && brew services start redis)
REDIS_URL=redis://localhost:6379

# Generate with: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars-long

# From @BotFather on Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFGhijklmnopqrstuvwxyz

# TON testnet for development
TON_RPC_URL=https://testnet.toncenter.com/api/v2
TON_API_KEY=your-toncenter-api-key
TON_NETWORK=testnet
PLATFORM_WALLET_ADDRESS=EQD...your-testnet-wallet-address
PLATFORM_WALLET_MNEMONIC=word1 word2 word3 ... word24

CORS_ORIGIN=*
